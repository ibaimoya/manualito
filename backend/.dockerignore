# Este es el .dockerignore efectivo para todos los servicios porque el
# build context de docker-compose es ./backend.

# Artefactos locales de Python y herramientas de desarrollo.
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
**/.pytest_cache/
.ruff_cache/
**/.ruff_cache/
.mypy_cache/
**/.mypy_cache/

# Cachés de modelos montados como volúmenes en runtime; nunca deben entrar
# en el contexto de build porque inflan la transferencia y pueden contener
# symlinks/reparse points incompatibles con Docker en Windows.
ocr/.paddleocr_cache/
**/.paddleocr_cache/
ocr/.ocr_cache/
**/.ocr_cache/
rag/.hf_cache/
**/.hf_cache/
