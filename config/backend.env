# Variables de runtime para los servicios del backend. #

OCR_URL=http://ocr:8001
RAG_URL=http://rag:8002
LLM_URL=http://llm:8003
LLM_UNLOAD_BEFORE_OCR=true

AUTH_COOKIE_SECURE=false
PASSWORD_HASH_CONCURRENCY=4
FRONTEND_PUBLIC_URL=http://localhost:5173
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM_EMAIL=no-reply@manualito.local
EMAIL_VERIFICATION_TOKEN_MINUTES=1440
PASSWORD_RESET_TOKEN_MINUTES=30
AUTH_EMAIL_RESEND_RATE_LIMIT=3/minute
AUTH_EMAIL_VERIFY_RATE_LIMIT=30/minute
AUTH_PASSWORD_FORGOT_RATE_LIMIT=5/minute
AUTH_PASSWORD_RESET_RATE_LIMIT=10/minute
MANUAL_STORAGE_DIR=/app/storage/manual-assets
GAME_SEARCH_RATE_LIMIT=120/minute
CONVERSATION_CREATE_RATE_LIMIT=30/minute

CHROMA_URL=http://chroma:8000
CHROMA_COLLECTION=manualito_manuals
EMBEDDING_MODEL=intfloat/multilingual-e5-small
HF_HOME=/home/appuser/.cache/huggingface
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python

OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi4:14b
OLLAMA_KEEP_ALIVE=5m
OLLAMA_HOST=ollama:11434
