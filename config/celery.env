# Configuración de Redis y Celery para productores, workers, Beat y Flower. #

REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_DB=0
CELERY_RESULT_DB=1
CELERY_VISIBILITY_TIMEOUT=3600
CELERY_RESULT_EXPIRES=3600
CELERY_GPU_SOFT_TIME_LIMIT=300
CELERY_GPU_HARD_TIME_LIMIT=360
CELERY_MANUAL_PAGE_SOFT_TIME_LIMIT=900
CELERY_MANUAL_PAGE_HARD_TIME_LIMIT=1080
CELERY_MANUAL_FINALIZE_SOFT_TIME_LIMIT=900
CELERY_MANUAL_FINALIZE_HARD_TIME_LIMIT=1080
CELERY_RAG_SOFT_TIME_LIMIT=600
CELERY_RAG_HARD_TIME_LIMIT=720
CELERY_MAIL_SOFT_TIME_LIMIT=60
CELERY_MAIL_HARD_TIME_LIMIT=90
CELERY_MAINTENANCE_SOFT_TIME_LIMIT=60
CELERY_MAINTENANCE_HARD_TIME_LIMIT=90
